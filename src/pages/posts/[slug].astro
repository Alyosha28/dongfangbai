---
// Updated dynamic post route
// src/pages/posts/[slug].astro
//
// This replaces the existing posts/[slug].astro (which likely renders the
// markdown directly into Site). We now wrap the rendered Markdown in the
// new <Post /> component (with marginalia + chapter gutter).

import { getCollection } from 'astro:content';
import Site from '../../layouts/Site.astro';
import Post from '../../components/Post.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((p) => !p.data.draft)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Site view="post" title={`${entry.data.caseId} · ${entry.data.title} — dongfangbai.com`} description={entry.data.subtitle}>
  <Post entry={entry} Content={Content} />
</Site>
