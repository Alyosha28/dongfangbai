---
// Hero · 「歌未竟·东方白」首屏巨字 + 战术装饰
import type { CollectionEntry } from 'astro:content';

interface Props {
  latestPost?: CollectionEntry<'posts'>;
}
const { latestPost } = Astro.props;
const latestHref = latestPost ? `/posts/${latestPost.slug}` : '#archive';
const markerCaseId = latestPost?.data.caseId ?? 'CASE-NEW';
const markerDate = latestPost?.data.date ?? '——';
---
<div class="hero">
  <div class="hero-deco tl">
    <div class="cross">╋</div>
    <div><span class="lbl">NERV.TAC</span></div>
    <div>GRID 35-Y2-K4</div>
    <div>STATUS · ACTIVE</div>
  </div>
  <div class="hero-deco br">
    <div><span class="lbl">A.T.FIELD</span></div>
    <div>SYNC 99.7%</div>
    <div>COMM · ONLINE</div>
    <div class="cross" style="margin-top:4px">╋</div>
  </div>
  <div class="hero-marker">{markerCaseId} · INCOMING TRANSMISSION · {markerDate}</div>
  <h1 class="hero-title">
    <span class="row">
      <span class="char" style="--i:0">歌</span><span class="char" style="--i:1">未</span><span class="char accent-char" style="--i:2">竟</span>
    </span>
    <span class="row">
      <span class="char" style="--i:3">东</span><span class="char" style="--i:4">方</span><span class="char accent-char" style="--i:5">白</span>
    </span>
  </h1>
  <div class="hero-tagline">
    <span class="line">// STUDENT · MARKET · NOTES · A.T.FIELD ACTIVE</span>
    <span class="line cn">一个学生 · 在读历史 · 看市场 · 写字</span>
  </div>
  <nav class="hero-nav">
    <a href={latestHref}><span class="arrow">──→</span> INCOMING TRANSMISSION / 最新通讯</a>
    <a href="#archive"><span class="arrow">──→</span> ARCHIVE / 档案</a>
    <a href="/about"><span class="arrow">──→</span> OPERATOR / 履历</a>
  </nav>
</div>
