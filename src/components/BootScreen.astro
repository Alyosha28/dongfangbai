---
// BootScreen · NERV-style 启动序列 — REFINED
// Denser HUD with 4 telemetry corners + diagnostic panel + progressive log
---
<div class="boot-screen" id="bootScreen">
  <div class="boot-warn-stripe"></div>
  <div class="boot-warn-stripe-bot"></div>

  <!-- 4 corners with real telemetry -->
  <div class="boot-corner tl">
    <div style="color: var(--accent); font-weight: 600; letter-spacing: 0.32em; margin-bottom: 8px; font-size: 10px;">▲ NERV.TAC · BOOT SEQ</div>
    <div>SEQ · 2026.05.15-A</div>
    <div>GRID · 35-Y2-K4</div>
    <div>CLEARANCE · <span style="color: var(--hero-gold)">LV-1</span></div>
  </div>
  <div class="boot-corner tr">
    <div style="color: var(--accent); font-weight: 600; letter-spacing: 0.32em; margin-bottom: 8px; font-size: 10px;">▲ TARGET · 东方白</div>
    <div>BUILD 20260515</div>
    <div>CASE · <span style="color: var(--hero-gold)">CASE-001</span></div>
    <div>SYNC · <span style="color: var(--hud-green)">PRE-MOUNT</span></div>
  </div>
  <div class="boot-corner bl">
    <div style="color: var(--accent); font-weight: 600; letter-spacing: 0.32em; margin-bottom: 8px; font-size: 10px;">▲ ATMOSPHERE</div>
    <div>立夏 · 第 11 日</div>
    <div>GRID 35-Y2-K4</div>
    <div>OPS · ONLINE</div>
  </div>
  <div class="boot-corner br">
    <div style="color: var(--accent); font-weight: 600; letter-spacing: 0.32em; margin-bottom: 8px; font-size: 10px;">▲ DISPATCH</div>
    <div>ARCHIVE · 1 / ∞</div>
    <div>UPTIME · 000d 14:32</div>
    <div>STATUS · <span style="color: var(--hud-green)">● ONLINE</span></div>
  </div>

  <div class="boot-logo-wrap">
    <div class="boot-logo-top">SOUL · 灵魂 — BOOT SEQUENCE INITIATED</div>
    <div class="boot-logo-svg">
      <svg viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg" width="340" height="340">
        <polygon class="boot-hex" points="150,18 270,82 270,218 150,282 30,218 30,82"></polygon>
        <polygon class="boot-hex-inner" points="150,48 240,98 240,202 150,252 60,202 60,98"></polygon>
        <line class="boot-cross" x1="150" y1="0" x2="150" y2="300"></line>
        <line class="boot-cross" x1="0" y1="150" x2="300" y2="150"></line>
        <text class="boot-logo-text" x="150" y="150" text-anchor="middle" dominant-baseline="central">秋</text>
      </svg>
    </div>
    <div class="boot-logo-bottom">
      <span class="line-1">歌 未 竟 · 东 方 白</span>
      <span class="line-2">FINAL · WHITE · INITIALIZING</span>
      <span class="de">DAS LIED IST NOCH NICHT ZU ENDE GESUNGEN</span>
    </div>
  </div>

  <div class="boot-status" id="bootStatus">
    <span class="dot"></span>
    <span class="lbl">ALL SYSTEMS</span>
    <span class="val">ONLINE</span>
    <span class="dim">·</span>
    <span class="lbl">SYNC</span>
    <span class="val">99.7%</span>
    <span class="dim">·</span>
    <span class="lbl">NERV LINK</span>
    <span class="val">ESTABLISHED</span>
  </div>

  <div class="boot-esc-hint" id="bootEscHint">
    <span class="kbd">ESC</span>
    <span class="or">/</span>
    <span class="kbd">click</span>
    <span class="lbl">to skip →</span>
  </div>

  <div class="boot-progress" id="bootProgress"><div class="boot-progress-bar"></div></div>

  <button class="boot-skip" id="bootSkip">SKIP / ENTER ↵</button>
</div>
