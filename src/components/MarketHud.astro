---
// A.T.Field Market Watch HUD · 固定右上,只在 home 显示
---
<div class="market-hud" id="marketHud">
  <div class="market-hud-head">
    <span>▼ A.T.FIELD · MARKET</span>
    <span class="pulse"></span>
  </div>
  <div class="market-hud-body" id="marketBody">
    <div class="market-row">
      <span class="sym">SHCOMP</span>
      <span class="val" data-sym="sh">3274.18</span>
      <span class="pct up" data-pct="sh">+0.43%↑</span>
    </div>
    <div class="market-row">
      <span class="sym">SZCOMP</span>
      <span class="val" data-sym="sz">10422.51</span>
      <span class="pct down" data-pct="sz">-0.21%↓</span>
    </div>
    <div class="market-row">
      <span class="sym">HSI</span>
      <span class="val" data-sym="hk">19281.05</span>
      <span class="pct up" data-pct="hk">+1.12%↑</span>
    </div>
    <div class="market-row">
      <span class="sym">SP500</span>
      <span class="val" data-sym="us">5847.32</span>
      <span class="pct up" data-pct="us">+0.18%↑</span>
    </div>
  </div>
  <div class="market-foot">
    <span>SYNC: <span class="sync-val" id="marketSync">99.7%</span></span>
    <span id="marketCase">CASE-007</span>
  </div>
</div>
